local RunService = game:GetService('RunService')
local Players = game:GetService('Players')
local UserInputService = game:GetService('UserInputService')
local TweenService = game:GetService('TweenService')
local localPlayer = Players.LocalPlayer
local camera = workspace.CurrentCamera

local Settings = {
    fov           = 150,
    smoothing     = 1,
    autoAttack    = false,
    espEnabled    = true,
    aimbotEnabled = true,
    aimTarget     = "Head",
    fovColor      = Color3.fromRGB(255, 100, 100),
}

-- ══════════════════════════════════════
--           ESP
-- ══════════════════════════════════════
local ESPPlayers = {}

local function createESP(Player)
    if ESPPlayers[Player] then return end
    local Drawings = {
        Box    = Drawing.new('Square'),
        Name   = Drawing.new('Text'),
        Health = Drawing.new('Square'),
        HealthBG = Drawing.new('Square'),
    }
    Drawings.Name.Size    = 13
    Drawings.Name.Center  = true
    Drawings.Name.Outline = true
    Drawings.Name.Font    = Drawing.Fonts.UI
    Drawings.Name.Color   = Color3.fromRGB(255, 255, 255)

    local conn = RunService.RenderStepped:Connect(function()
        local show = false
        if Settings.espEnabled and Player.Character then
            local HRP = Player.Character:FindFirstChild('HumanoidRootPart')
            local Hum = Player.Character:FindFirstChild('Humanoid')
            if HRP and Hum then
                local pos, onScreen = camera:WorldToViewportPoint(HRP.Position)
                if onScreen then
                    show = true
                    local scale = 1 / (pos.Z * math.tan(math.rad(camera.FieldOfView * 0.5)) * 2) * 1000
                    local w  = math.floor(4.5 * scale)
                    local h  = math.floor(6   * scale)
                    local x  = math.floor(pos.X - w * 0.5)
                    local y  = math.floor(pos.Y - h * 0.5 + 0.5 * scale)
                    local hp = math.clamp(Hum.Health / Hum.MaxHealth, 0, 1)
                    local r  = math.floor(255 * (1 - hp))
                    local g  = math.floor(255 * hp)

                    Drawings.Box.Size      = Vector2.new(w, h)
                    Drawings.Box.Position  = Vector2.new(x, y)
                    Drawings.Box.Color     = Color3.fromRGB(r, g, 50)
                    Drawings.Box.Thickness = 1
                    Drawings.Box.Filled    = false
                    Drawings.Box.Visible   = true
                    Drawings.Box.ZIndex    = 2

                    Drawings.Name.Text     = Player.Name
                    Drawings.Name.Position = Vector2.new(x + w * 0.5, y - 16)
                    Drawings.Name.Visible  = true

                    Drawings.HealthBG.Size     = Vector2.new(4, h)
                    Drawings.HealthBG.Position = Vector2.new(x - 7, y)
                    Drawings.HealthBG.Color    = Color3.fromRGB(30, 30, 30)
                    Drawings.HealthBG.Filled   = true
                    Drawings.HealthBG.Visible  = true
                    Drawings.HealthBG.ZIndex   = 1

                    local hh = math.floor(h * hp)
                    Drawings.Health.Size     = Vector2.new(4, hh)
                    Drawings.Health.Position = Vector2.new(x - 7, y + (h - hh))
                    Drawings.Health.Color    = Color3.fromRGB(r, g, 50)
                    Drawings.Health.Filled   = true
                    Drawings.Health.Visible  = true
                    Drawings.Health.ZIndex   = 2
                end
            end
        end
        if not show then
            for _, d in pairs(Drawings) do d.Visible = false end
        end
    end)

    ESPPlayers[Player] = { drawings = Drawings, connection = conn }
end

local function removeESP(Player)
    if ESPPlayers[Player] then
        ESPPlayers[Player].connection:Disconnect()
        for _, d in pairs(ESPPlayers[Player].drawings) do d:Remove() end
        ESPPlayers[Player] = nil
    end
end

for _, v in pairs(Players:GetPlayers()) do
    if v ~= localPlayer then coroutine.wrap(createESP)(v) end
end
Players.PlayerAdded:Connect(function(v) task.delay(1, function() coroutine.wrap(createESP)(v) end) end)
Players.PlayerRemoving:Connect(removeESP)

-- ══════════════════════════════════════
--           FOV RING
-- ══════════════════════════════════════
local FOVring = Drawing.new("Circle")
FOVring.Thickness    = 1.5
FOVring.NumSides     = 64
FOVring.Transparency = 1

RunService.RenderStepped:Connect(function()
    FOVring.Position = camera.ViewportSize / 2
    FOVring.Radius   = Settings.fov
    FOVring.Visible  = Settings.aimbotEnabled
    FOVring.Color    = Settings.fovColor
end)

-- ══════════════════════════════════════
--           АИМБОТ
-- ══════════════════════════════════════
local function getClosest()
    if not Settings.aimbotEnabled then return nil end
    local cCF  = camera.CFrame
    local cPos = cCF.Position
    local closest, best = nil, math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if player == localPlayer then continue end
        local char = player.Character
        if not char then continue end
        local hum  = char:FindFirstChild("Humanoid")
        local part = char:FindFirstChild(Settings.aimTarget) or char:FindFirstChild("HumanoidRootPart")
        if not (hum and part) then continue end
        if hum.Health <= 0 then continue end

        -- Используем экранное расстояние от центра, не проекцию
        local sp, onScr = camera:WorldToScreenPoint(part.Position)
        if not onScr then continue end
        local screenDist = (Vector2.new(sp.X, sp.Y) - camera.ViewportSize / 2).Magnitude
        if screenDist <= Settings.fov and screenDist < best then
            best    = screenDist
            closest = player
        end
    end
    return closest
end

local function aimAtTarget(target)
    if not target or not target.Character then return end
    local part = target.Character:FindFirstChild(Settings.aimTarget)
                 or target.Character:FindFirstChild("HumanoidRootPart")
    if not part then return end
    camera.CFrame = camera.CFrame:Lerp(
        CFrame.new(camera.CFrame.Position, part.Position),
        Settings.smoothing
    )
end

local function isVisible(target)
    if not target or not target.Character then return false end
    local part = target.Character:FindFirstChild(Settings.aimTarget)
                 or target.Character:FindFirstChild("Head")
    if not part then return false end
    local origin = camera.CFrame.Position
    local dir    = (part.Position - origin).Unit * 1000
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {localPlayer.Character, camera}
    local result = workspace:Raycast(origin, dir, params)
    return result and result.Instance:IsDescendantOf(target.Character)
end

local isAttacking = false
local renderConn
renderConn = RunService.RenderStepped:Connect(function()
    if UserInputService:IsKeyDown(Enum.KeyCode.Delete) then
        renderConn:Disconnect(); FOVring:Remove(); return
    end

    local aiming   = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)

    if aiming and Settings.aimbotEnabled then
        local target = getClosest()
        if target then
            aimAtTarget(target)
            if Settings.autoAttack and isVisible(target) then
                if not isAttacking then mouse1press(); isAttacking = true end
            else
                if isAttacking then mouse1release(); isAttacking = false end
            end
        else
            if isAttacking then mouse1release(); isAttacking = false end
        end
    else
        if isAttacking then mouse1release(); isAttacking = false end
    end
end)

