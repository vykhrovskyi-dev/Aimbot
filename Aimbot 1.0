-- ── helpers ──────────────────────────────────────────────
local function makeSection(label)
    local f = Instance.new("Frame", Scroll)
    f.Size            = UDim2.new(1, -8, 0, 20)
    f.BackgroundTransparency = 1
    f.LayoutOrder     = 0

    local line = Instance.new("Frame", f)
    line.Size            = UDim2.new(1, 0, 0, 1)
    line.Position        = UDim2.new(0, 0, 0.5, 0)
    line.BackgroundColor3 = Color3.fromRGB(60, 40, 80)
    line.BorderSizePixel = 0

    local lbl = Instance.new("TextLabel", f)
    lbl.Size            = UDim2.new(0, 100, 1, 0)
    lbl.Position        = UDim2.new(0, 8, 0, 0)
    lbl.BackgroundColor3 = Color3.fromRGB(10,10,15)
    lbl.BorderSizePixel = 0
    lbl.Text            = " " .. label .. " "
    lbl.TextColor3      = Color3.fromRGB(180,50,255)
    lbl.Font            = Enum.Font.GothamBold
    lbl.TextSize        = 11
    return f
end

local function makeToggle(label, icon, key, order)
    local row = Instance.new("Frame", Scroll)
    row.Size            = UDim2.new(1, -8, 0, 44)
    row.BackgroundColor3 = Color3.fromRGB(20, 20, 28)
    row.BorderSizePixel = 0
    row.LayoutOrder     = order
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

    local ico = Instance.new("TextLabel", row)
    ico.Size            = UDim2.new(0, 36, 1, 0)
    ico.BackgroundTransparency = 1
    ico.Text            = icon
    ico.TextSize        = 18
    ico.Font            = Enum.Font.GothamBold
    ico.TextColor3      = Color3.fromRGB(200,150,255)

    local lbl = Instance.new("TextLabel", row)
    lbl.Size            = UDim2.new(1, -80, 1, 0)
    lbl.Position        = UDim2.new(0, 36, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text            = label
    lbl.TextColor3      = Color3.fromRGB(220,220,235)
    lbl.Font            = Enum.Font.Gotham
    lbl.TextSize        = 13
    lbl.TextXAlignment  = Enum.TextXAlignment.Left

    -- Toggle pill
    local pill = Instance.new("Frame", row)
    pill.Size            = UDim2.new(0, 44, 0, 22)
    pill.Position        = UDim2.new(1, -52, 0.5, -11)
    pill.BackgroundColor3 = Color3.fromRGB(40,40,50)
    pill.BorderSizePixel = 0
    Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame", pill)
    knob.Size            = UDim2.new(0, 18, 0, 18)
    knob.Position        = UDim2.new(0, 2, 0.5, -9)
    knob.BackgroundColor3 = Color3.fromRGB(130,130,140)
    knob.BorderSizePixel = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local function refresh()
        local on = Settings[key]
        TweenService:Create(pill,  TweenInfo.new(0.2), { BackgroundColor3 = on and Color3.fromRGB(140,40,220) or Color3.fromRGB(40,40,50) }):Play()
        TweenService:Create(knob,  TweenInfo.new(0.2), { Position = on and UDim2.new(0,24,0.5,-9) or UDim2.new(0,2,0.5,-9),
                                                          BackgroundColor3 = on and Color3.fromRGB(255,255,255) or Color3.fromRGB(130,130,140) }):Play()
    end
    refresh()

    row.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            Settings[key] = not Settings[key]
            refresh()
        end
    end)

    return row, refresh
end

local function makeSlider(label, icon, key, minV, maxV, order)
    local row = Instance.new("Frame", Scroll)
    row.Size            = UDim2.new(1, -8, 0, 58)
    row.BackgroundColor3 = Color3.fromRGB(20, 20, 28)
    row.BorderSizePixel = 0
    row.LayoutOrder     = order
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

    local ico = Instance.new("TextLabel", row)
    ico.Size            = UDim2.new(0, 36, 0, 28)
    ico.Position        = UDim2.new(0, 0, 0, 0)
    ico.BackgroundTransparency = 1
    ico.Text            = icon
    ico.TextSize        = 18
    ico.Font            = Enum.Font.GothamBold
    ico.TextColor3      = Color3.fromRGB(200,150,255)

    local lbl = Instance.new("TextLabel", row)
    lbl.Size            = UDim2.new(0.6, 0, 0, 28)
    lbl.Position        = UDim2.new(0, 36, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text            = label
    lbl.TextColor3      = Color3.fromRGB(220,220,235)
    lbl.Font            = Enum.Font.Gotham
    lbl.TextSize        = 13
    lbl.TextXAlignment  = Enum.TextXAlignment.Left

    local valLbl = Instance.new("TextLabel", row)
    valLbl.Size            = UDim2.new(0, 50, 0, 28)
    valLbl.Position        = UDim2.new(1, -56, 0, 0)
    valLbl.BackgroundTransparency = 1
    valLbl.Text            = tostring(Settings[key])
    valLbl.TextColor3      = Color3.fromRGB(180,50,255)
    valLbl.Font            = Enum.Font.GothamBold
    valLbl.TextSize        = 13
    valLbl.TextXAlignment  = Enum.TextXAlignment.Right

    -- Track
    local track = Instance.new("Frame", row)
    track.Size            = UDim2.new(1, -20, 0, 6)
    track.Position        = UDim2.new(0, 10, 0, 36)
    track.BackgroundColor3 = Color3.fromRGB(40,40,55)
    track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame", track)
    fill.Size            = UDim2.new((Settings[key] - minV)/(maxV - minV), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(160,50,255)
    fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local handle = Instance.new("Frame", track)
    handle.Size            = UDim2.new(0, 14, 0, 14)
    handle.AnchorPoint     = Vector2.new(0.5, 0.5)
    handle.Position        = UDim2.new(fill.Size.X.Scale, 0, 0.5, 0)
    handle.BackgroundColor3 = Color3.fromRGB(220,180,255)
    handle.BorderSizePixel = 0
    Instance.new("UICorner", handle).CornerRadius = UDim.new(1, 0)

    local sliding = false
    local function setVal(input)
        local abs    = track.AbsolutePosition
        local size   = track.AbsoluteSize
        local pct    = math.clamp((input.Position.X - abs.X) / size.X, 0, 1)
        local val    = math.floor(minV + (maxV - minV) * pct)
        Settings[key] = val
        fill.Size      = UDim2.new(pct, 0, 1, 0)
        handle.Position = UDim2.new(pct, 0, 0.5, 0)
        valLbl.Text    = tostring(val)
    end
    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = true; setVal(i)
        end
    end)
    track.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then setVal(i) end
    end)

    return row
end

local function makeTargetSelector(order)
    local row = Instance.new("Frame", Scroll)
    row.Size            = UDim2.new(1, -8, 0, 52)
    row.BackgroundColor3 = Color3.fromRGB(20, 20, 28)
    row.BorderSizePixel = 0
    row.LayoutOrder     = order
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

    local ico = Instance.new("TextLabel", row)
    ico.Size           = UDim2.new(0, 36, 0, 28)
    ico.BackgroundTransparency = 1
    ico.Text            = "🎯"
    ico.TextSize        = 18
    ico.Font            = Enum.Font.GothamBold
    ico.TextColor3      = Color3.fromRGB(200,150,255)

    local lbl = Instance.new("TextLabel", row)
    lbl.Size            = UDim2.new(1, -50, 0, 28)
    lbl.Position        = UDim2.new(0, 36, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text            = "Aim Target"
    lbl.TextColor3      = Color3.fromRGB(220,220,235)
    lbl.Font            = Enum.Font.Gotham
    lbl.TextSize        = 13
    lbl.TextXAlignment  = Enum.TextXAlignment.Left

    local btnContainer = Instance.new("Frame", row)
    btnContainer.Size             = UDim2.new(1, -16, 0, 26)
    btnContainer.Position         = UDim2.new(0, 8, 0, 24)
    btnContainer.BackgroundTransparency = 1
    btnContainer.BorderSizePixel  = 0

    local UILList = Instance.new("UIListLayout", btnContainer)
    UILList.FillDirection = Enum.FillDirection.Horizontal
    UILList.Padding       = UDim.new(0, 6)

    local function makeBtn(label, targetKey)
        local btn = Instance.new("TextButton", btnContainer)
        btn.Size            = UDim2.new(0.5, -3, 1, 0)
        btn.BackgroundColor3 = Settings.aimTarget == targetKey and Color3.fromRGB(140,40,220) or Color3.fromRGB(35,35,48)
        btn.BorderSizePixel = 0
        btn.Text            = label
        btn.TextColor3      = Color3.fromRGB(230,230,245)
        btn.Font            = Enum.Font.GothamBold
        btn.TextSize        = 12
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

        btn.MouseButton1Click:Connect(function()
            Settings.aimTarget = targetKey
            for _, child in ipairs(btnContainer:GetChildren()) do
                if child:IsA("TextButton") then
                    TweenService:Create(child, TweenInfo.new(0.15), {
                        BackgroundColor3 = Color3.fromRGB(35,35,48)
                    }):Play()
                end
            end
            TweenService:Create(btn, TweenInfo.new(0.15), {
                BackgroundColor3 = Color3.fromRGB(140,40,220)
            }):Play()
        end)
        return btn
    end

    makeBtn("HEAD", "Head")
    makeBtn("BODY", "HumanoidRootPart")

    return row
end

-- ── build sections ────────────────────────────────────────
makeSection("ESP")
makeToggle("ESP Boxes",      "👁",  "espEnabled",   1)

makeSection("AIMBOT")
makeToggle("Aimbot",         "🖱",  "aimbotEnabled",2)
makeToggle("Auto Attack",    "⚔",  "autoAttack",   3)
makeToggle("Team Check",     "🛡",  "teamCheck",    4)
makeSlider("FOV Radius",     "🔵",  "fov",  30, 500, 5)
makeSlider("Smoothing",      "〰",  "smoothing", 1, 30, 6)   -- stored ×10
makeTargetSelector(7)

-- Fix smoothing slider: store as 1–30 → divide by 100 when using
-- We override: store real value in fov, and smoothing 1–30 as 1–30, applied as /100
-- Patch aimAtTarget to use Settings.smoothing/100
local _origSmoothing = Settings.smoothing
-- Use smoothing as 1-30 mapped to 0.01-0.30
local function getSmoothingValue()
    return Settings.smoothing / 100
end

-- Patch aimAtTarget
local function aimAtTarget2(target)
    if not target or not target.Character then return end
    local part = target.Character:FindFirstChild(Settings.aimTarget)
                 or target.Character:FindFirstChild("HumanoidRootPart")
    if not part then return end
    camera.CFrame = camera.CFrame:Lerp(
        CFrame.new(camera.CFrame.Position, part.Position),
        getSmoothingValue()
    )
end

-- Replace aimAtTarget in renderConn with aimAtTarget2
renderConn:Disconnect()
isAttacking = false
renderConn = RunService.RenderStepped:Connect(function()
    if UserInputService:IsKeyDown(Enum.KeyCode.Delete) then
        renderConn:Disconnect(); FOVring:Remove(); return
    end
    local pressing = Settings.autoAttack
                     or UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    if pressing and Settings.aimbotEnabled then
        local target = getClosest()
        if target then
            aimAtTarget2(target)
            if isVisible(target) then
                if not isAttacking then mouse1press(); isAttacking = true end
            else
                if isAttacking then mouse1release(); isAttacking = false end
            end
        else
            if isAttacking then mouse1release(); isAttacking = false end
        end
    else
        if isAttacking then mouse1release(); isAttacking = false end
    end
end)

-- ── menu toggle ───────────────────────────────────────────
local menuOpen = false
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        menuOpen = not menuOpen
        Main.Visible = menuOpen
        TweenService:Create(blur, TweenInfo.new(0.3), { Size = menuOpen and 8 or 0 }):Play()
        if menuOpen then
            Main.Size = UDim2.new(0, 0, 0, 0)
            Main.Position = UDim2.new(0.5, 0, 0.5, 0)
            TweenService:Create(Main, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Size     = UDim2.new(0, 340, 0, 420),
                Position = UDim2.new(0.5, -170, 0.5, -210),
            }):Play()
        end
    end
end)

print("[Phantom] Loaded — RightShift to open menu")
